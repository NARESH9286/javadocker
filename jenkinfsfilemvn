pipeline {
    agent {
  label 'mylinux'
}
    stages {
        stage('install maven software') {
            steps {
               sh 'sudo dnf install maven -y'
            }
        }
     stage('creation of package maven') {
            steps {
             sh 'mvn clean package'
            }
        }
     stage('releasing pacakge') {
            steps {
             archiveArtifacts artifacts: 'target/*.jar', followSymlinks: false
            }
        }
    }
}
